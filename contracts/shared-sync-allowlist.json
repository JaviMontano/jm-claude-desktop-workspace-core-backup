{
  "version": "1.1.0",
  "policy": {
    "mode": "allowlist-only-fail-closed",
    "intendedTarget": "shared-curated-repository",
    "copyBehavior": "files-only"
  },
  "allowlist": [
    "CLAUDE.md",
    "CONSTITUTION.md",
    "README.md",
    "_flows/**",
    "_scripts/**",
    "_templates/**",
    "_index-agents.md",
    "_index-commands.md",
    "_index-routing.md",
    "_index-skills.md",
    "_index-workflows.md",
    "_versions.md",
    "profiles/**",
    "contracts/**",
    "references/**",
    "assets/**",
    "skills/**",
    "agents/**",
    "adapters/antigravity/README.md",
    "packs/metodologia-proposal-engine/**",
    "scripts/bootstrap-workspace.sh",
    "scripts/capture-local-profiles.sh",
    "scripts/check-capabilities.sh",
    "scripts/doctor.sh",
    "scripts/export-antigravity.sh",
    "scripts/refresh-from-core.sh",
    "scripts/sync-shared.sh",
    "tests/**",
    "specs/**"
  ],
  "denylist": [
    ".git/**",
    "local/**",
    ".remember/**",
    "workspaces/**",
    "**/session-state.json",
    "**/.env",
    "**/.env.*",
    "**/*.local",
    "**/outputs/**",
    "**/research/**",
    "**/verification/**"
  ]
}
